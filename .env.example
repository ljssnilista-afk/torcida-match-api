# Copie este arquivo para .env e preencha os valores

# MongoDB Atlas — obtenha em https://cloud.mongodb.com (gratuito)
MONGODB_URI=mongodb+srv://SEU_USUARIO:SUA_SENHA@cluster0.xxxxx.mongodb.net/torcidamatch?retryWrites=true&w=majority

# JWT — use qualquer string longa e aleatória (ex: gere em https://randomkeygen.com)
JWT_SECRET=sua_chave_secreta_muito_longa_aqui_troque_isso

# Porta (Railway/Render definem automaticamente via PORT)
PORT=3001

# Frontend URL (para CORS) — troque pelo seu domínio em produção
CLIENT_URL=http://localhost:5173
